{
  "agentspec_version": "26.1.0",
  "component_type": "Flow",
  "id": "blog-image-prompt-agent-flow",
  "name": "Blog Image Prompt Agent",
  "description": "Stateless leaf agent that generates blog image-prompts (text descriptions, NOT images) from a blog draft. Returns {prompts: BlogImagePrompt[], notes} where BlogImagePrompt = {placement, prompt, rationale}.",
  "metadata": {
    "cinatra": {
      "type": "flow",
      "packageName": "@cinatra-ai/blog-image-prompt-agent",
      "hitlScreens": [
        "@cinatra-ai/context-selection-agent:context-selector"
      ],
      "llm": {
        "preferredProvider": "openai",
        "preferredModel": "gpt-5.5"
      },
      "contextSlots": [
        {
          "slotId": "imagePromptContext",
          "acceptedArtifactExtensions": [
            "@cinatra-ai/brand-voice-artifact",
            "@cinatra-ai/blog-post-artifact"
          ],
          "selectionMode": "interactive",
          "resolutionMode": "accumulate",
          "minItems": 0,
          "maxItems": 5
        }
      ]
    }
  },
  "inputs": [
    {
      "title": "draft",
      "type": "object"
    },
    {
      "title": "count",
      "type": "integer",
      "default": 3
    },
    {
      "title": "placements",
      "type": "array",
      "json_schema": {
        "items": {
          "type": "string"
        }
      },
      "default": [
        "cover",
        "inline",
        "social"
      ]
    },
    {
      "title": "style",
      "type": "string",
      "default": ""
    },
    {
      "title": "brandKeywords",
      "type": "array",
      "json_schema": {
        "items": {
          "type": "string"
        }
      },
      "default": []
    },
    {
      "title": "cinatra_run_id",
      "type": "string",
      "default": ""
    },
    {
      "title": "imagePromptContextParentPackageName",
      "type": "string",
      "default": "@cinatra-ai/blog-image-prompt-agent"
    },
    {
      "title": "imagePromptContextSlotId",
      "type": "string",
      "default": "imagePromptContext"
    },
    {
      "title": "projectId",
      "type": "string",
      "default": ""
    }
  ],
  "outputs": [
    {
      "title": "prompts",
      "type": "array",
      "json_schema": {
        "items": {
          "type": "object"
        }
      }
    },
    {
      "title": "notes",
      "type": "string"
    }
  ],
  "start_node": {
    "$component_ref": "start"
  },
  "nodes": [
    {
      "$component_ref": "start"
    },
    {
      "$component_ref": "context_imagePromptContext"
    },
    {
      "$component_ref": "generate"
    },
    {
      "$component_ref": "end"
    }
  ],
  "control_flow_connections": [
    {
      "component_type": "ControlFlowEdge",
      "name": "start_to_generate",
